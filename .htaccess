# Serve the static homepage at the site root, ahead of WordPress
<IfModule mod_dir.c>
DirectoryIndex index.html index.php
</IfModule>

# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Let WordPress handle its own root query requests (Elementor/post previews, ?p=, ?page_id=)
# instead of the static index.html. A bare "/" with no such query still serves the static homepage.
# Matches both the empty root and the index.html DirectoryIndex mapping (LiteSpeed resolves it early).
RewriteCond %{QUERY_STRING} (^|&)(p|page_id|preview|preview_id|elementor-preview)= [NC]
RewriteRule ^(index\.html)?$ /index.php [L]

# Redirect removed Practitioners page (and any sub-path) -> AI Council
RewriteRule ^practitioners(/.*)?$ /aicouncil/ [R=301,L]

RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>
# END WordPress
